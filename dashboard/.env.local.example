# Supabase — Erstelle ein Projekt auf https://supabase.com
# Project Settings > API > URL und anon key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Ohne diese Variablen läuft das Dashboard im Demo-Modus:
# - Kein Login nötig
# - Scan-Daten in localStorage
# - Alle Features funktionieren, nur nicht persistent
